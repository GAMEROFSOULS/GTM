# =============================================================
# Reloadium GTM Agent — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# =============================================================

# n8n webhook URL — triggers the GTM lead discovery agent
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/your-webhook-id

# Supabase project URL (https://xxx.supabase.co)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase public anon key (safe for browser — enforces RLS)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
